# gitignore for Agents-Memory

# LanceDB 本地向量索引（可从 errors/ 重新 embed，不需要版本控制）
vectors/

# Docker 数据目录（大文件，本地持久化即可）
docker/data/

# VS Code / MCP 本机配置（含本地绝对路径）
.vscode/

# 运行期共享记忆数据（包含私有项目路径、错误记录与本地热区索引）
index.md
memory/projects.md
memory/rules.md
errors/*.md
errors/archive/
.agents-memory/

# Runtime logs
logs/

# Runtime PID files
*.pid

# 本地环境变量（含 API Key）
docker/.env
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# MacOS
.DS_Store
.coverage
