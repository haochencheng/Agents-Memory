#!/usr/bin/env python3.12
"""
amem — Agents-Memory CLI 全局命令

安装方式（只需一次）:
  bash /path/to/Agents-Memory/scripts/install-cli.sh

安装后在任意目录使用:
  amem register              # 一键注册当前目录的项目
  amem register /path/proj   # 注册指定路径的项目
  amem copilot-setup [id]    # 安装仓库级 Copilot 自动激活指令
    amem agent-list            # 查看内置 agent adapter 列表
    amem agent-setup <agent> [target]  # 为指定 agent 安装集成
  amem bridge-install <id>   # 安装 bridge instruction
  amem doctor [target]       # 检查项目是否完整接入
  amem list                  # 列出活跃错误记录
  amem sync                  # 推送规则到所有已注册项目
  amem stats                 # 错误统计
  amem search <keyword>      # 关键词搜索
  amem new                   # 交互式记录新错误
  amem promote <id>          # 升级为 instruction 规则
  amem update-index          # 更新 index.md
"""
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from agents_memory.app import main as app_main


def main() -> None:
  return app_main()


if __name__ == "__main__":
    main()
